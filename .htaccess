# ========================================
# 底辺AI音楽フェス - Cache-Control設定
# ========================================

# mod_headers が有効な場合のみ
<IfModule mod_headers.c>

  # HTML - キャッシュしない（更新をすぐ反映）
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JSON（gallery.json / songs.json 等）- キャッシュしない
  <FilesMatch "\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # PHP レスポンス - キャッシュしない（API）
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache"
  </FilesMatch>

  # CSS / JS - 長めキャッシュ（ファイル名に変更がない限り）
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>

  # 画像 - 長めキャッシュ（ロゴ等はほぼ変わらない）
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  # フォント
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  # sitemap / robots - 1日キャッシュ
  <FilesMatch "(sitemap\.xml|robots\.txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

</IfModule>

# ========================================
# GZIP圧縮（ついでに設定）
# ========================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ========================================
# ETags無効化（Cache-Controlと競合防止）
# ========================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
